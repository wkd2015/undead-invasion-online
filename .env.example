# 复制为 .env.local 后按需填写。以下密钥/链接由你后续提供时再写入，勿提交真实值。

# 站点公开访问 URL（canonical、sitemap、OG；本地开发可不设）
# NEXT_PUBLIC_SITE_URL=https://example.com

# Cloudflare R2 / CDN 静态资源前缀（配合 next.config assetPrefix）
# NEXT_PUBLIC_ASSET_PREFIX=https://your-r2-or-cdn.example.com

# 游戏 iframe 页面地址（H5 游戏源站）
# NEXT_PUBLIC_GAME_IFRAME_URL=

# Google Analytics 4 衡量 ID（仅在前端有值时注入脚本）
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Microsoft Clarity 项目 ID（仅在前端有值时注入脚本）
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Vercel 部署时由平台自动注入，一般无需手写
# VERCEL_URL=
